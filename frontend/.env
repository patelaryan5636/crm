# Frontend Environment Configuration
# In development, Vite proxies /api to VITE_BACKEND_URL automatically.
# When using ngrok for the frontend, update both URLs to your ngrok URLs:
#   VITE_API_URL=https://your-backend-ngrok.ngrok-free.app/api
#   VITE_BACKEND_URL=https://your-backend-ngrok.ngrok-free.app
VITE_API_URL=http://localhost:5000/api
VITE_BACKEND_URL=http://localhost:5000
